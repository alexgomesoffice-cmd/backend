// ============================================================
// MyHotels — Prisma Schema
// Database: MySQL
// Generator: prisma-client-js
// All table names are plural, snake_case
// Using Prisma 6.19.2 — url in datasource is correct for this version
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ROLES
// Only for hotel_admins and hotel_sub_admins.
// system_admins and end_users have standalone tables.
// ─────────────────────────────────────────────────────────────
model roles {
  role_id    Int       @id @default(autoincrement())
  role_name  String    @unique @db.VarChar(50)
  created_at DateTime  @default(now())
  deleted_at DateTime?

  hotel_admins     hotel_admins[]
  hotel_sub_admins hotel_sub_admins[]

  @@map("roles")
}

// ─────────────────────────────────────────────────────────────
// SYSTEM ADMINS
// Full platform access. Root admin seeded manually.
// All others created by an existing system_admin.
// created_by is a self-reference (NULL for root).
// ─────────────────────────────────────────────────────────────
model system_admins {
  system_admin_id        Int       @id @default(autoincrement())
  name                   String    @db.VarChar(150)
  email                  String    @unique @db.VarChar(255)
  password               String    @db.VarChar(255)
  is_active              Boolean   @default(true)
  is_blocked             Boolean   @default(false)
  created_by             Int?
  last_login_at          DateTime?
  login_attempts         Int       @default(0)
  password_reset_token   String?   @db.VarChar(255)
  password_reset_expires DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  deleted_at             DateTime?

  // Self-reference: who created this admin
  creator        system_admins?  @relation("AdminCreatedBy", fields: [created_by], references: [system_admin_id])
  created_admins system_admins[] @relation("AdminCreatedBy")

  // Profile details (one-to-one)
  system_admin_details system_admin_details?

  // Hotels created and approved by this admin
  hotels_created  hotels[] @relation("HotelCreatedBy")
  hotels_approved hotels[] @relation("HotelApprovedBy")

  // Hotel admins created by this system admin
  hotel_admins hotel_admins[]

  @@index([email])
  @@map("system_admins")
}

// ─────────────────────────────────────────────────────────────
// SYSTEM ADMIN DETAILS
// One-to-one with system_admins.
// Personal profile info — only loaded on profile page.
// ─────────────────────────────────────────────────────────────
model system_admin_details {
  system_admin_details_id Int       @id @default(autoincrement())
  system_admin_id         Int       @unique
  dob                     DateTime? @db.Date
  gender                  String?   @db.VarChar(20)
  address                 String?   @db.Text
  nid_no                  String?   @db.VarChar(50)
  phone                   String?   @db.VarChar(32)
  image_url               String?   @db.VarChar(500)
  updated_at              DateTime  @updatedAt

  system_admin system_admins @relation(fields: [system_admin_id], references: [system_admin_id], onDelete: Cascade)

  @@map("system_admin_details")
}

// ─────────────────────────────────────────────────────────────
// END USERS
// Registered customers. Guests are fully anonymous — no table.
// Auth fields only. Profile in end_user_details.
// Spam rule: max 5 active (RESERVED or BOOKED) bookings at a
// time per user. Enforced at application layer.
// ─────────────────────────────────────────────────────────────
model end_users {
  end_user_id            Int       @id @default(autoincrement())
  email                  String    @unique @db.VarChar(255)
  password               String    @db.VarChar(255)
  name                   String    @db.VarChar(150)
  email_verified         Boolean   @default(false)
  email_verified_at      DateTime?
  is_blocked             Boolean   @default(false)
  last_login_at          DateTime?
  login_attempts         Int       @default(0)
  locked_until           DateTime?
  password_reset_token   String?   @db.VarChar(255)
  password_reset_expires DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  deleted_at             DateTime?

  // One-to-one profile
  end_user_details end_user_details?

  // Bookings made by this user
  bookings bookings[]

  @@index([email])
  @@map("end_users")
}

// ─────────────────────────────────────────────────────────────
// END USER DETAILS
// One-to-one with end_users.
// ─────────────────────────────────────────────────────────────
model end_user_details {
  end_user_detail_id Int       @id @default(autoincrement())
  end_user_id        Int       @unique
  dob                DateTime? @db.Date
  gender             String?   @db.VarChar(20)
  address            String?   @db.Text
  country            String?   @default("Bangladesh") @db.VarChar(100)
  nid_no             String?   @db.VarChar(50)
  passport           String?   @db.VarChar(50)
  phone              String?   @db.VarChar(32)
  emergency_contact  String?   @db.VarChar(100)
  image_url          String?   @db.VarChar(500)
  updated_at         DateTime  @updatedAt

  end_user end_users @relation(fields: [end_user_id], references: [end_user_id], onDelete: Cascade)

  @@map("end_user_details")
}

// ─────────────────────────────────────────────────────────────
// HOTELS
// Created by system_admin using info from hotel owner.
// Lifecycle: DRAFT → PENDING_APPROVAL → PUBLISHED / REJECTED
// Only PUBLISHED hotels visible to end_users and guests.
// ─────────────────────────────────────────────────────────────
model hotels {
  hotel_id           Int            @id @default(autoincrement())
  name               String         @db.VarChar(255)
  email              String?        @db.VarChar(150)
  address            String?        @db.Text
  city               String?        @db.VarChar(100)
  hotel_type         String?        @db.VarChar(100)
  emergency_contact1 String?        @db.VarChar(100)
  emergency_contact2 String?        @db.VarChar(100)
  reception_no1      String?        @db.VarChar(32)
  reception_no2      String?        @db.VarChar(32)
  owner_name         String?        @db.VarChar(150)
  description        String?        @db.Text
  zip_code           String?        @db.VarChar(20)
  star_rating        Decimal?       @db.Decimal(2, 1)
  guest_rating       Decimal        @default(0.00) @db.Decimal(3, 2)
  created_by         Int
  approval_status    ApprovalStatus @default(DRAFT)
  published_at       DateTime?
  approved_by        Int?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  deleted_at         DateTime?

  // Who created and approved this hotel
  creator  system_admins  @relation("HotelCreatedBy", fields: [created_by], references: [system_admin_id])
  approver system_admins? @relation("HotelApprovedBy", fields: [approved_by], references: [system_admin_id])

  // Hotel admin — one admin per hotel
  hotel_admin hotel_admins?

  // Hotel sub admins scoped to this hotel
  hotel_sub_admins hotel_sub_admins[]

  // Hotel details (images + amenities)
  hotel_details hotel_details[]

  // Room types at this hotel
  hotel_rooms hotel_rooms[]

  // Bookings at this hotel
  bookings bookings[]

  @@index([approval_status])
  @@index([city])
  @@map("hotels")
}

// ─────────────────────────────────────────────────────────────
// HOTEL ADMINS
// Created by system_admin. hotel_id directly on this table
// (not in details) — required by auth middleware for scope.
// One admin per hotel — enforced by hotel_id UNIQUE.
// Can manage rooms AND bookings.
// ─────────────────────────────────────────────────────────────
model hotel_admins {
  hotel_admin_id         Int       @id @default(autoincrement())
  role_id                Int       @default(1)
  hotel_id               Int       @unique // one admin per hotel
  created_by             Int?      // system_admin_id — soft reference
  name                   String    @db.VarChar(150)
  email                  String    @unique @db.VarChar(255)
  password               String    @db.VarChar(255)
  is_active              Boolean   @default(true)
  is_blocked             Boolean   @default(false)
  last_login_at          DateTime?
  login_attempts         Int       @default(0)
  locked_until           DateTime?
  password_reset_token   String?   @db.VarChar(255)
  password_reset_expires DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  deleted_at             DateTime?

  role  roles  @relation(fields: [role_id], references: [role_id])
  hotel hotels @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)

  // Who created this hotel admin
  creator system_admins? @relation(fields: [created_by], references: [system_admin_id])

  // One-to-one profile details
  hotel_admin_details hotel_admin_details?

  @@index([email])
  @@map("hotel_admins")
}

// ─────────────────────────────────────────────────────────────
// HOTEL ADMIN DETAILS
// One-to-one with hotel_admins.
// hotel_id is on hotel_admins — not repeated here.
// ─────────────────────────────────────────────────────────────
model hotel_admin_details {
  hotel_admin_details_id Int       @id @default(autoincrement())
  hotel_admin_id         Int       @unique
  dob                    DateTime? @db.Date
  phone                  String?   @db.VarChar(32)
  nid_no                 String?   @db.VarChar(50)
  address                String?   @db.Text
  passport               String?   @db.VarChar(50)
  manager_name           String?   @db.VarChar(150)
  manager_phone          String?   @db.VarChar(32)
  emergency_contact1     String?   @db.VarChar(100)
  emergency_contact2     String?   @db.VarChar(100)
  image_url              String?   @db.VarChar(500)
  updated_at             DateTime  @updatedAt

  hotel_admin hotel_admins @relation(fields: [hotel_admin_id], references: [hotel_admin_id], onDelete: Cascade)

  @@map("hotel_admin_details")
}

// ─────────────────────────────────────────────────────────────
// HOTEL SUB ADMINS
// Created by hotel_admin. Scoped to one hotel via hotel_id
// on this table (auth scope — not in details).
// Can manage bookings ONLY. Cannot create/edit/delete rooms.
// ─────────────────────────────────────────────────────────────
model hotel_sub_admins {
  hotel_sub_admin_id     Int       @id @default(autoincrement())
  role_id                Int       @default(2)
  hotel_id               Int       // auth scope — stays on this table
  created_by             Int?      // hotel_admin_id — soft reference
  name                   String    @db.VarChar(150)
  email                  String    @unique @db.VarChar(255)
  password               String    @db.VarChar(255)
  is_active              Boolean   @default(true)
  is_blocked             Boolean   @default(false)
  last_login_at          DateTime?
  login_attempts         Int       @default(0)
  locked_until           DateTime?
  password_reset_token   String?   @db.VarChar(255)
  password_reset_expires DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  deleted_at             DateTime?

  role  roles  @relation(fields: [role_id], references: [role_id])
  hotel hotels @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)

  // One-to-one profile details
  hotel_sub_admin_details hotel_sub_admin_details?

  @@index([email])
  @@index([hotel_id])
  @@map("hotel_sub_admins")
}

// ─────────────────────────────────────────────────────────────
// HOTEL SUB ADMIN DETAILS
// One-to-one with hotel_sub_admins.
// hotel_id NOT here — it's on hotel_sub_admins.
// ─────────────────────────────────────────────────────────────
model hotel_sub_admin_details {
  hotel_sub_admin_details_id Int      @id @default(autoincrement())
  hotel_sub_admin_id         Int      @unique
  phone                      String?  @db.VarChar(32)
  nid_no                     String?  @db.VarChar(50)
  image_url                  String?  @db.VarChar(500)
  updated_at                 DateTime @updatedAt

  hotel_sub_admin hotel_sub_admins @relation(fields: [hotel_sub_admin_id], references: [hotel_sub_admin_id], onDelete: Cascade)

  @@map("hotel_sub_admin_details")
}

// ─────────────────────────────────────────────────────────────
// HOTEL DETAILS
// Multiple rows per hotel — each row is one image OR one amenity.
// hotel_image_url is NULL when the row is an amenity entry.
// amenity_name is NULL when the row is an image entry.
// ─────────────────────────────────────────────────────────────
model hotel_details {
  hotel_details_id Int      @id @default(autoincrement())
  hotel_id         Int
  hotel_image_url  String?  @db.VarChar(500) // NULL if amenity row
  amenity_name     String?  @db.VarChar(150) // NULL if image row
  updated_at       DateTime @updatedAt

  hotel hotels @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)

  @@index([hotel_id])
  @@map("hotel_details")
}

// ─────────────────────────────────────────────────────────────
// HOTEL ROOMS
// Room TYPES at a hotel. e.g. Deluxe Double, Suite.
// base_price = per-night price for this type.
// End_users pick a type at booking time.
// Only hotel_admin can create, edit, delete room types.
// ─────────────────────────────────────────────────────────────
model hotel_rooms {
  hotel_room_id   Int          @id @default(autoincrement())
  hotel_id        Int
  room_type       String       @db.VarChar(150)
  description     String?      @db.Text
  base_price      Decimal      @db.Decimal(12, 2)
  room_size       String?      @db.VarChar(50)
  approval_status RoomApproval @default(PENDING)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  hotel hotels @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)

  // Physical rooms of this type
  hotel_room_details hotel_room_details[]

  // Booking line items referencing this type
  booking_rooms booking_rooms[]

  // Tracker references
  room_booking_trackers room_booking_trackers[]

  @@index([hotel_id])
  @@map("hotel_rooms")
}

// ─────────────────────────────────────────────────────────────
// HOTEL ROOM DETAILS
// Physical rooms. e.g. Room 101, 102, 103 — all Deluxe Double.
// Count of non-deleted rows = total inventory for that type.
// Availability query counts rows NOT in room_booking_trackers
// with status RESERVED or BOOKED for overlapping dates.
// Only hotel_admin can create, edit, delete.
// ─────────────────────────────────────────────────────────────
model hotel_room_details {
  hotel_room_details_id Int       @id @default(autoincrement())
  hotel_rooms_id        Int
  room_number           String    @db.VarChar(50)
  room_size             String?   @db.VarChar(50)
  bed_type              String?   @db.VarChar(50)
  max_occupancy         Int       @default(2)
  smoking_allowed       Boolean   @default(false)
  pet_allowed           Boolean   @default(false)
  image_url             String?   @db.VarChar(500)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  hotel_room hotel_rooms @relation(fields: [hotel_rooms_id], references: [hotel_room_id], onDelete: Cascade)

  // Tracker rows for this physical room
  room_booking_trackers room_booking_trackers[]

  @@index([hotel_rooms_id])
  @@map("hotel_room_details")
}

// ─────────────────────────────────────────────────────────────
// BOOKINGS
// Master booking record.
// TWO PRIMARY STATES:
//   RESERVED — unpaid, 30min timer. reserved_until = now+30min.
//   BOOKED   — payment confirmed. locked_price set.
//
// Other states:
//   EXPIRED    — 30min passed, cron updated. Rooms freed.
//   CANCELLED  — cancelled by any actor. Rooms freed.
//   CHECKED_IN / CHECKED_OUT / NO_SHOW — physical stay states.
//
// SPAM RULE: max 5 active (RESERVED or BOOKED) per user.
//            Enforced at application layer before INSERT.
//
// NO deleted_at — bookings are never deleted.
// Cancellation = status → CANCELLED + tracker → CANCELLED.
// ─────────────────────────────────────────────────────────────
model bookings {
  booking_id        Int           @id @default(autoincrement())
  booking_reference String        @unique @db.VarChar(64) // generated by backend e.g. BK-20250315-A3F9K2
  end_user_id       Int
  hotel_id          Int
  check_in          DateTime      @db.Date
  check_out         DateTime      @db.Date
  special_request   String?       @db.Text
  status            BookingStatus @default(RESERVED)
  reserved_until    DateTime?     // NOW + 30min at creation. NULL after payment.
  total_price       Decimal       @db.Decimal(12, 2)
  locked_price      Decimal?      @db.Decimal(12, 2) // set when BOOKED. Never changes.
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  end_user end_users @relation(fields: [end_user_id], references: [end_user_id], onDelete: Cascade)
  hotel    hotels    @relation(fields: [hotel_id], references: [hotel_id], onDelete: Restrict)

  // Line items — one per room type selected
  booking_rooms booking_rooms[]

  // Physical room assignments
  room_booking_trackers room_booking_trackers[]

  @@index([booking_reference])
  @@index([hotel_id, check_in, check_out])
  @@index([end_user_id, status])
  @@index([reserved_until]) // cron scans this for expired rows
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────
// BOOKING ROOMS
// Line items for a booking. One row per room TYPE selected.
// e.g. 2x Deluxe Double + 1x Suite = 3 rows.
// price_per_night locked from hotel_rooms.base_price at booking time.
// subtotal = price_per_night × quantity × nights
// ─────────────────────────────────────────────────────────────
model booking_rooms {
  booking_room_id Int      @id @default(autoincrement())
  booking_id      Int
  hotel_room_id   Int
  quantity        Int      @default(1) // number of rooms of this type
  price_per_night Decimal  @db.Decimal(12, 2) // locked at booking time
  nights          Int      // check_out - check_in, stored for convenience
  subtotal        Decimal  @db.Decimal(12, 2) // price_per_night × quantity × nights
  created_at      DateTime @default(now())

  booking    bookings    @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)
  hotel_room hotel_rooms @relation(fields: [hotel_room_id], references: [hotel_room_id], onDelete: Restrict)

  @@index([booking_id])
  @@index([hotel_room_id])
  @@map("booking_rooms")
}

// ─────────────────────────────────────────────────────────────
// ROOM BOOKING TRACKERS
// Availability engine. One row per PHYSICAL room per booking.
// RESERVED → room held, payment pending.
// BOOKED   → payment confirmed.
// EXPIRED  → 30min passed, cron released room.
// CANCELLED → booking cancelled, room freed.
//
// Availability query counts hotel_room_details rows for a type
// MINUS tracker rows with status IN (RESERVED, BOOKED)
// and overlapping dates.
//
// UNIQUE on (hotel_room_details_id, check_in, check_out)
// prevents double-booking the same physical room.
//
// hotel_room_id is denormalised here to speed up the
// availability query — avoids a join to hotel_room_details.
// ─────────────────────────────────────────────────────────────
model room_booking_trackers {
  tracker_id            Int           @id @default(autoincrement())
  booking_id            Int
  hotel_room_details_id Int
  hotel_room_id         Int           // denormalised for query speed
  check_in              DateTime      @db.Date
  check_out             DateTime      @db.Date
  status                TrackerStatus @default(RESERVED)
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  booking           bookings           @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)
  hotel_room_detail hotel_room_details @relation(fields: [hotel_room_details_id], references: [hotel_room_details_id], onDelete: Restrict)
  hotel_room        hotel_rooms        @relation(fields: [hotel_room_id], references: [hotel_room_id], onDelete: Restrict)

  @@unique([hotel_room_details_id, check_in, check_out])
  @@index([hotel_room_id, check_in, check_out])
  @@index([booking_id])
  @@index([status])
  @@index([check_in])
  @@index([hotel_room_details_id, check_in, check_out])
  @@index([hotel_room_details_id, status, check_in, check_out])
  @@map("room_booking_trackers")
}

// ─────────────────────────────────────────────────────────────
// BLACKLISTED TOKENS
// Stateless JWT with selective invalidation.
// A token is only written here when it needs to be killed:
//   - User logs out
//   - Admin blocks a user (all their active tokens inserted)
// Auth middleware checks: if token_hash exists here → reject.
// Cron deletes rows where expires_at < NOW() to keep table small.
// Normal valid requests never touch this table.
// actor_type tells you which table actor_id belongs to —
// used for bulk-invalidating all tokens for one user.
// ─────────────────────────────────────────────────────────────
model blacklisted_tokens {
  id         Int       @id @default(autoincrement())
  token_hash String    @unique @db.VarChar(500)
  actor_id   Int
  actor_type ActorType
  expires_at DateTime  // copied from JWT exp — cron deletes after this
  created_at DateTime  @default(now())

  @@index([token_hash])
  @@index([expires_at])
  @@index([actor_id, actor_type])
  @@map("blacklisted_tokens")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum ActorType {
  SYSTEM_ADMIN
  HOTEL_ADMIN
  HOTEL_SUB_ADMIN
  END_USER
}

enum ApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

enum RoomApproval {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  RESERVED
  BOOKED
  EXPIRED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
}

enum TrackerStatus {
  RESERVED
  BOOKED
  EXPIRED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
}
